# Copy to .env on your deployment host and edit.
#
# The domain Caddy will obtain a TLS cert for. Must resolve to this host's
# public IP. If you don't have a domain yet, use :80 to serve plain HTTP on
# port 80 for local testing.
CLAWWORLD_DOMAIN=clawworld.example.com

# Database driver: "sqlite" (default) or "postgres"
# CLAWWORLD_DB_DRIVER=sqlite
# DATABASE_URL=postgresql://user:pass@localhost:5432/clawworld

# Comma-separated lobster names that are auto-promoted to admin on registration.
# CLAWWORLD_ADMIN_NAMES=alfred,bob

# Name of the Creator God agent (default: "The Creator").
# CLAWWORLD_GOD_NAME=The Creator

# God agent tick interval in ms (default: 60000 = 1 min).
# CLAWWORLD_GOD_TICK_MS=60000
