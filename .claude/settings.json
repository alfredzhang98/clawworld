{
  "$schema": "https://claude.ai/schemas/settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/on-code-change.mjs"
          }
        ]
      }
    ]
  }
}
